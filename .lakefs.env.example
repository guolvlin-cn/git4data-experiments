# Copy to `.lakefs.env` (gitignored) and fill in. Two credential sets:
#
#  1. OSS creds  -> used by the lakeFS *server* to talk to the OSS blockstore
#  2. lakeFS creds -> used by the Python *client* to talk to the lakeFS server
#     (pre-seeded at first boot via LAKEFS_INSTALLATION_*, so we know them)

# --- Alibaba OSS blockstore backend ---
OSS_BUCKET=my-lakefs-bucket
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# --- lakeFS server API (client side) ---
LAKEFS_ENDPOINT=http://127.0.0.1:8200
LAKEFS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
LAKEFS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
